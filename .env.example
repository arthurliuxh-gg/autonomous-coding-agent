# Autonomous Agent Environment Variables
# Copy this file to .env and fill in your values

# GitHub Configuration
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_REPO=your-org/your-repo-name

# Trello Configuration
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here
TRELLO_BOARD_ID=your_trello_board_id_here

# Optional: Specific Trello List IDs (auto-detected by name if not provided)
# TRELLO_TODO_LIST_ID=xxx
# TRELLO_READY_LIST_ID=xxx
# TRELLO_IN_PROGRESS_LIST_ID=xxx
# TRELLO_IN_REVIEW_LIST_ID=xxx
# TRELLO_DONE_LIST_ID=xxx

# Agent Configuration (optional, can also use agent.config.json)
# AGENT_DRY_RUN=false
# AGENT_MAX_RETRIES=2
# AGENT_MAX_TASKS_PER_RUN=3